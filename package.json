{
  "name": "countroster",
  "private": true,
  "version": "0.0.0",
  "description": "A local-first anything-tracker. iOS + Android + Web from a shared TypeScript core.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
