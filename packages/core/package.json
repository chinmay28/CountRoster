{
  "name": "@countroster/core",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript mirror of the CountRoster domain: types for the web client and an in-memory test double for its component tests. The production implementation lives in server/ (Go).",
  "license": "AGPL-3.0-only",
  "author": "Chinmay Manjunath",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "uuidv7": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
