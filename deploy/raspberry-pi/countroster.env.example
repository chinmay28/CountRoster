# CountRoster server configuration.
# Installed to /etc/countroster/countroster.env and read by the systemd unit.
# Edit, then `sudo systemctl restart countroster`.

# Port to listen on.
PORT=8787

# Bind address. 0.0.0.0 = reachable from other devices on your LAN/Tailscale.
HOST=0.0.0.0

# The SQLite database file — the single source of truth for every client.
# Keep this OUTSIDE the app directory so code updates never touch your data.
COUNTROSTER_DB=/var/lib/countroster/countroster.sqlite

# Built PWA to serve on the same origin. Defaults to the app's own apps/web/dist,
# so you normally don't need to set this. Uncomment to override.
# WEB_DIST=/opt/countroster/apps/web/dist
